{
  "name": "metalsmith-unified-markdown",
  "version": "0.1.1",
  "description": "A Metalsmith plugin to render markdown files to HTML using unified/remark or micromark for better performance",
  "keywords": [
    "markdown",
    "metalsmith",
    "metalsmith-plugin",
    "static-site",
    "unified",
    "remark",
    "micromark",
    "performance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wernerglinka/metalsmith-unified-markdown"
  },
  "bugs": {
    "url": "https://github.com/wernerglinka/metalsmith-unified-markdown/issues"
  },
  "homepage": "https://github.com/wernerglinka/metalsmith-unified-markdown",
  "license": "MIT",
  "author": "Werner Glinka <werner@glinka.co>",
  "type": "module",
  "exports": "./src/index.js",
  "files": [
    "src/**/*.js",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "changelog": "auto-changelog -u --commit-limit false --ignore-commit-pattern '^((dev|chore|ci):|Release)'",
    "test": "node --test --test-timeout=15000 'test/**/*.test.js'",
    "coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-timeout=15000 'test/**/*.test.js'",
    "test:coverage": "npm run coverage",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "pre-release": "npm run lint:check && npm run format:check && npm test && npx metalsmith-plugin-mcp-server validate .",
    "release:patch": "./scripts/release.sh patch --ci",
    "release:minor": "./scripts/release.sh minor --ci",
    "release:major": "./scripts/release.sh major --ci",
    "release:check": "npm run lint:check && release-it --dry-run",
    "depcheck": "depcheck"
  },
  "dependencies": {
    "dlv": "^1.1.3",
    "dset": "^3.1.4",
    "hast-util-to-html": "^9.0.5",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-hast": "^13.2.1",
    "micromark": "^4.0.2",
    "micromark-extension-gfm": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "auto-changelog": "^2.5.1",
    "depcheck": "^1.4.7",
    "markdown-it": "^14.1.1",
    "metalsmith": "^2.7.0",
    "release-it": "^20.0.1"
  },
  "peerDependencies": {
    "metalsmith": "^2.5.0"
  },
  "engines": {
    "node": ">= 22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
